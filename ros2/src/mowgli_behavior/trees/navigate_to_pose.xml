<!--
  navigate_to_pose.xml — Custom Nav2 BT for NavigateToPose action.

  Based on Nav2's navigate_w_recovery_and_replanning_only_if_path_becomes_invalid.xml
  (NOT the default 1-Hz-replan tree). The default tree calls ComputePathToPose
  every 1 s, and Smac on this robot's costmap produces a path whose initial
  heading flips ±10° between consecutive plans when the robot is near edges
  / inflation gradients. FTC re-enters PRE_ROTATE on each new plan (angle_err
  above its 10° threshold), spending 200-400 ms aligning before it can
  resume FOLLOWING — so the effective forward speed collapses to ~2 cm/s
  near the dock-staging approach (observed 2026-05-14 with HOME from
  outside-boundary recovery). The replan-only-if-invalid pattern lets FTC
  follow a single stable path until the costmap actually invalidates it
  (new obstacle on the path) or the goal changes.

  Customisation over the stock Nav2 tree: adds GoalCheckerSelector (required
  when controller_server defines multiple goal_checker_plugins) and keeps
  the comment about ClearGlobalCostmap-Context omission.
-->
<root BTCPP_format="4" main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <RecoveryNode number_of_retries="6" name="NavigateRecovery">
      <PipelineSequence name="NavigateWithReplanning">
        <ControllerSelector selected_controller="{selected_controller}" default_controller="FollowPath" topic_name="controller_selector"/>
        <GoalCheckerSelector selected_goal_checker="{selected_goal_checker}" default_goal_checker="stopped_goal_checker" topic_name="goal_checker_selector"/>
        <PlannerSelector selected_planner="{selected_planner}" default_planner="GridBased" topic_name="planner_selector"/>
        <RateController hz="1.0">
          <!--
            Replan only if the existing path is invalid OR the goal has been
            updated. Otherwise the previous path stays in {path} and the
            downstream FollowPath keeps tracking it — no PRE_ROTATE flap.

            ClearGlobalCostmap-Context recovery removed: under the no-lidar
            config the global_costmap has only static_layer + keepout_filter
            + inflation, and ClearEntireCostmap forces those layers to
            re-subscribe and resets current_=false, which puts Nav2 into a
            loop where every plan attempt times out. The bottom-level
            RecoveryFallback below still has a costmap-clear action if real
            recovery is needed.
          -->
          <Fallback name="FallbackComputePathToPose">
            <ReactiveSequence name="CheckIfNewPathNeeded">
              <Inverter>
                <GlobalUpdatedGoal/>
              </Inverter>
              <IsPathValid path="{path}"/>
            </ReactiveSequence>
            <ComputePathToPose goal="{goal}" path="{path}" planner_id="{selected_planner}" error_code_id="{compute_path_error_code}"/>
          </Fallback>
        </RateController>
        <RecoveryNode number_of_retries="1" name="FollowPath">
          <FollowPath path="{path}" controller_id="{selected_controller}" goal_checker_id="{selected_goal_checker}" error_code_id="{follow_path_error_code}"/>
          <Sequence>
            <WouldAControllerRecoveryHelp error_code="{follow_path_error_code}"/>
            <ClearEntireCostmap name="ClearLocalCostmap-Context" service_name="local_costmap/clear_entirely_local_costmap"/>
          </Sequence>
        </RecoveryNode>
      </PipelineSequence>
      <Sequence>
        <Fallback>
          <WouldAControllerRecoveryHelp error_code="{follow_path_error_code}"/>
          <WouldAPlannerRecoveryHelp error_code="{compute_path_error_code}"/>
        </Fallback>
        <ReactiveFallback name="RecoveryFallback">
          <GoalUpdated/>
          <!--
            Wedge-safe, dock-safe recovery (OBSTACLE_WEDGE_RECOVERY_SPEC.md,
            Part B). This tree is shared by EVERY NavigateToPose: coverage
            transit, HOME, AND opennav_docking's nav-to-staging approach. NO blind
            MOTION recovery belongs here — each one breaks a different consumer:
              * Spin drives the robot in circles with NO planned path on the map
                (operator-visible "tourne en rond / pas de trajectoire") when it is
                boxed in beside an obstacle during coverage/transit.
              * BackUp backs the robot AWAY from its goal. During the dock-staging
                approach the dock sits amid obstacle inflation, so the approach
                intermittently aborts "collision ahead"; a reverse-out then retreats
                from the dock and it never seats (field 2026-07-22: "the docking
                server avoids the obstacles / cannot dock").
            So recovery is costmap-clear → wait-for-the-costmap-to-settle → retry
            planning, with no erratic motion. A genuinely un-plannable wedge simply
            exhausts the RecoveryNode retries and fails the action, which the
            higher-level BT handles per consumer: coverage escalates to the
            detour-and-continue net (decideDetour, which DOES route a blade-off
            transit around the obstacle with full global-costmap knowledge), HOME
            retries, and DockRobot retries the whole dock. The wedge reverse-out
            lives ONLY where it is destination-aware — the coverage controller's
            opt-in FTC obstacle_reverse — never in this goal-blind shared tree.
          -->
          <RoundRobin name="RecoveryActions">
            <Sequence name="ClearingActions">
              <ClearEntireCostmap name="ClearLocalCostmap-Subtree" service_name="local_costmap/clear_entirely_local_costmap"/>
              <ClearEntireCostmap name="ClearGlobalCostmap-Subtree" service_name="global_costmap/clear_entirely_global_costmap"/>
            </Sequence>
            <Wait wait_duration="5.0"/>
          </RoundRobin>
        </ReactiveFallback>
      </Sequence>
    </RecoveryNode>
  </BehaviorTree>
</root>
