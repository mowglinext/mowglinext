# Build artifacts
build/
log/
*.pyc
__pycache__/
*.egg-info/

# IDE
.vscode/
.idea/
*.iml
*.code-workspace
.DS_Store

# ROS2
*.bag
*.db3
ros2/install

# PlatformIO (firmware)
.pio/

# Node modules (GUI)
node_modules/

# Docker
.env.local
# Site-specific runtime config — written by install/mowglinext.sh from
# docker/.env.example. The example is the only tracked template.
docker/.env
docker/.env.old.*
# Generated by install/mowglinext.sh from install/compose/*.yml fragments.
docker/docker-compose.yaml
docker/docker-compose.yaml.old.*
# Site-specific runtime config — seeded by install/mowglinext.sh from
# install/config/. Operator edits (GUI Settings page, manual tuning)
# must survive `git pull` and the installer's `git reset --hard`.
docker/config/mowgli/mowgli_robot.yaml
docker/config/cyclonedds.xml
docker/config/mqtt/mosquitto.conf
docker/config/om/mower_config.sh
# Drive-motor autotune outputs — written at runtime (as root) by tune_drive_pid
# and managed via the GUI (gui/pkg/api/drive_tuning.go reads the mounted dir).
# Per-install runtime artifacts; tracking them wedges git checkout/rebase when
# the container rewrites them. Keep the dir (.gitkeep) so the bind-mount target
# exists on a fresh checkout.
docker/config/mowgli/drive_tuning/*
!docker/config/mowgli/drive_tuning/.gitkeep
install/.preset
install/.preset.consumed
install/logs/
# Fork-local installer override — set REPO_URL to point at your fork's registry.
install/lib/config.local.sh

# Secrets
*.pem
*.key
credentials.json
.claude/worktrees

# Mow-session monitor logs — committed selectively via `git add -f` for
# golden / failure-case reference runs; default-ignored to avoid bloating
# the repo with every development test.
docker/logs/mow_sessions/*.jsonl
!docker/logs/mow_sessions/.gitkeep
.playwright-mcp/
