<?xml version="1.0" encoding="UTF-8"?>
<CycloneDDS xmlns="https://cdds.io/config">
  <Domain id="any">
    <General>
      <Interfaces>
        <NetworkInterface autodetermine="true"/>
      </Interfaces>
    </General>
    <Discovery>
      <!-- Raised from default (9) to keep us comfortably above the
           total participant count once every container + short-lived
           CLI clients have joined. -->
      <MaxAutoParticipantIndex>500</MaxAutoParticipantIndex>
    </Discovery>
  </Domain>
</CycloneDDS>
